generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlserver"
}

model Asistencia {
  IdAsistencia     Int       @id(map: "PK__Asistenc__3956DEE66D823520") @default(autoincrement())

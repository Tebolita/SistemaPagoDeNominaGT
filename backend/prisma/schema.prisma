  EstadoPago           String?                @db.VarChar(20)
  FechaVencimiento     DateTime?              @db.DateTime
  IdUsuarioRegistra    Int
  Notas                String?                @db.VarChar(500)
  Activo               Boolean?
  FechaEliminacion     DateTime?              @db.DateTime
  DetalleVenta         DetalleVenta[]
  MovimientoFinanciero MovimientoFinanciero[]
  Cliente              Cliente?               @relation(fields: [IdCliente], references: [IdCliente], onDelete: NoAction, onUpdate: NoAction, map: "FK_Venta_Cliente")
  Usuario              Usuario                @relation(fields: [IdUsuarioRegistra], references: [IdUsuario], onUpdate: NoAction, map: "FK_Venta_Usuario")

  @@index([EstadoPago], map: "IX_Venta_EstadoPago")
  @@index([FechaVenta], map: "IX_Venta_FechaVenta")
  @@index([IdCliente], map: "IX_Venta_IdCliente")
}
